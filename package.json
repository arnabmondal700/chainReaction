{
  "name": "chainreaction-master",
  "version": "1.0.0",
  "description": "A turn-based strategy game built with vanilla HTML, CSS, and JavaScript — zero frameworks, zero dependencies.",
  "main": "build.js",
  "scripts": {
    "build": "node build.js",
    "build:min": "node build.js --minify",
    "test": "node --test tests/**/*.test.js",
    "test:tutorial": "node tests/tutorial.smoke.mjs",
    "test:dist": "npm run build:min && node tests/dist-build.smoke.mjs",
    "verify": "npm test && npm run test:tutorial && npm run test:dist"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "clean-css": "^5.3.3",
    "html-minifier-terser": "^7.2.0",
    "jsdom": "^29.1.1",
    "terser": "^5.49.0"
  }
}
